# 複製這個檔案為 .env.local,填入你的金鑰(.env.local 不會被 git 追蹤)

# ── Site URL（正式部署請改成正式網域）──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://zhinan.3854335.com

# ── AI 解讀(必填)────────────────────────────────────────
# 金鑰申請:https://aistudio.google.com/apikey(有免費額度)
GEMINI_API_KEY=your-api-key-here

# 選填:要使用的 Gemini 模型,預設 gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# ── 會員系統(選填,兩個都填才會啟用)──────────────────────
# Supabase Dashboard → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ── 每日額度(選填)──────────────────────────────────────
# ANON_DAILY_LIMIT=3
# MEMBER_DAILY_LIMIT=10
# PER_MINUTE_LIMIT=6

# ── Redis 限流(正式環境建議,選填)────────────────────────
# 未設定時會退回本機記憶體限流;Vercel/serverless 多實例正式上線建議設定
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Sentry error monitoring（可選）────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://your-public-key@your-org.ingest.sentry.io/your-project-id
# SENTRY_AUTH_TOKEN=sntrys_xxx
